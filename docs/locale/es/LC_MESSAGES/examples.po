#: ../../examples.md:141
msgid "Donation Tracker"
msgstr "Rastreador de Donaciones"

#: ../../examples.md:143
msgid "Track donation progress from paid invoices."
msgstr "Rastree el progreso de donaciones desde facturas pagadas."

#: ../../examples.md:145
#, python-brace-format
msgid ""
"from decimal import Decimal\n"
"\n"
"\n"
"class DonationTracker:\n"
"    def __init__(self, client: CryptoBotClient, goal_usd: Decimal):\n"
"        self.client = client\n"
"        self.goal_usd = goal_usd\n"
"\n"
"    def create_donation_invoice(self, donor: str, amount_usdt: float) -> "
"str:\n"
"        invoice = self.client.create_invoice(\n"
"            asset=Asset.USDT,\n"
"            amount=amount_usdt,\n"
"            description=\"Open-source donation\",\n"
"            payload=f\"donor:{donor}\",\n"
"            allow_comments=True,\n"
"            allow_anonymous=True,\n"
"            expires_in=3600,\n"
"        )\n"
"        return invoice.bot_invoice_url\n"
"\n"
"    def progress(self):\n"
"        invoices = self.client.get_invoices(status=Status.paid, "
"count=100)\n"
"        total = Decimal(\"0\")\n"
"\n"
"        for invoice in invoices:\n"
"            amount = Decimal(invoice.paid_amount or invoice.amount)\n"
"            paid_asset = invoice.paid_asset or invoice.asset.name\n"
"\n"
"            # Simple handling for stablecoins; convert non-USD assets as "
"needed.\n"
"            if paid_asset in {\"USDT\", \"USDC\"}:\n"
"                total += amount\n"
"\n"
"        pct = (total / self.goal_usd * Decimal(\"100\")) if self.goal_usd"
" > 0 else Decimal(\"0\")\n"
"        return {\"raised_usd\": str(total), \"goal_usd\": "
"str(self.goal_usd), \"percent\": str(round(pct, 2))}\n"
"\n"
"\n"
"tracker = DonationTracker(client, goal_usd=Decimal(\"10000\"))\n"
"print(\"Donate:\", tracker.create_donation_invoice(\"alice\", 25))\n"
"print(\"Progress:\", tracker.progress())\n"
msgstr ""
"from decimal import Decimal\n"
"\n"
"\n"
"class DonationTracker:\n"
"    def __init__(self, client: CryptoBotClient, goal_usd: Decimal):\n"
"        self.client = client\n"
"        self.goal_usd = goal_usd\n"
"\n"
"    def create_donation_invoice(self, donor: str, amount_usdt: float) -> "
"str:\n"
"        invoice = self.client.create_invoice(\n"
"            asset=Asset.USDT,\n"
"            amount=amount_usdt,\n"
"            description=\"Open-source donation\",\n"
"            payload=f\"donor:{donor}\",\n"
"            allow_comments=True,\n"
"            allow_anonymous=True,\n"
"            expires_in=3600,\n"
"        )\n"
"        return invoice.bot_invoice_url\n"
"\n"
"    def progress(self):\n"
"        invoices = self.client.get_invoices(status=Status.paid, "
"count=100)\n"
"        total = Decimal(\"0\")\n"
"\n"
"        for invoice in invoices:\n"
"            amount = Decimal(invoice.paid_amount or invoice.amount)\n"
"            paid_asset = invoice.paid_asset or invoice.asset.name\n"
"\n"
"            # Manejo simple para stablecoins; convertir activos no USD según sea necesario.\n"
"            if paid_asset in {\"USDT\", \"USDC\"}:\n"
"                total += amount\n"
"\n"
"        pct = (total / self.goal_usd * Decimal(\"100\")) if self.goal_usd"
" > 0 else Decimal(\"0\")\n"
"        return {\"raised_usd\": str(total), \"goal_usd\": "
"str(self.goal_usd), \"percent\": str(round(pct, 2))}\n"
"\n"
"\n"
"tracker = DonationTracker(client, goal_usd=Decimal(\"10000\"))\n"
"print(\"Donate:\", tracker.create_donation_invoice(\"alice\", 25))\n"
"print(\"Progress:\", tracker.progress())\n"

#: ../../examples.md:187
msgid "Webhook-Driven Fulfillment"
msgstr "Cumplimiento de Pedidos por Webhook"

#: ../../examples.md:189
msgid "Use the listener to mark orders as paid without polling."
msgstr "Use el listener para marcar pedidos como pagados sin necesidad de polling."

#: ../../examples.md:191
#, python-brace-format
msgid ""
"import os\n"
"\n"
"from cryptobot.webhook import InMemoryReplayKeyStore, Listener\n"
"\n"
"\n"
"def handle_webhook(headers, data):\n"
"    if data.get(\"update_type\") != \"invoice_paid\":\n"
"        return\n"
"\n"
"    payload = data.get(\"payload\", {})\n"
"    invoice_id = payload.get(\"invoice_id\")\n"
"    order_id = payload.get(\"payload\")  # value passed during "
"create_invoice(payload=...)\n"
"\n"
"    print(\"Fulfill order\", order_id, \"from invoice\", invoice_id)\n"
"\n"
"\n"
"listener = Listener(\n"
"    host=\"0.0.0.0\",\n"
"    callback=handle_webhook,\n"
"    api_token=os.environ[\"CRYPTOBOT_API_TOKEN\"],\n"
"    replay_store=InMemoryReplayKeyStore(),\n"
"    replay_ttl_seconds=3600,\n"
"    port=2203,\n"
"    url=\"/webhook\",\n"
"    log_level=\"info\",\n"
")\n"
"listener.listen()\n"
msgstr ""
"import os\n"
"\n"
"from cryptobot.webhook import InMemoryReplayKeyStore, Listener\n"
"\n"
"\n"
"def handle_webhook(headers, data):\n"
"    if data.get(\"update_type\") != \"invoice_paid\":\n"
"        return\n"
"\n"
"    payload = data.get(\"payload\", {})\n"
"    invoice_id = payload.get(\"invoice_id\")\n"
"    order_id = payload.get(\"payload\")  # valor pasado durante "
"create_invoice(payload=...)\n"
"\n"
"    print(\"Fulfill order\", order_id, \"from invoice\", invoice_id)\n"
"\n"
"\n"
"listener = Listener(\n"
"    host=\"0.0.0.0\",\n"
"    callback=handle_webhook,\n"
"    api_token=os.environ[\"CRYPTOBOT_API_TOKEN\"],\n"
"    replay_store=InMemoryReplayKeyStore(),\n"
"    replay_ttl_seconds=3600,\n"
"    port=2203,\n"
"    url=\"/webhook\",\n"
"    log_level=\"info\",\n"
")\n"
"listener.listen()\n"

#: ../../examples.md:221
msgid "Airdrop with Crypto Checks"
msgstr "Airdrop con Checks Criptográficos"

#: ../../examples.md:223
msgid "Create checks for a batch of users and track activations."
msgstr "Cree checks para un lote de usuarios y rastree las activaciones."

#: ../../examples.md:225
#, python-brace-format
msgid ""
"from cryptobot.models import Asset\n"
"\n"
"\n"
"def airdrop_checks(client: CryptoBotClient, user_ids: list, amount: "
"float, asset: Asset = Asset.USDT):\n"
"    \"\"\"Create pinned checks for a list of users.\"\"\"\n"
"    results = []\n"
"    for user_id in user_ids:\n"
"        try:\n"
"            check = client.create_check(\n"
"                asset=asset,\n"
"                amount=amount,\n"
"                pin_to_user_id=user_id,\n"
"            )\n"
"            results.append({\"user_id\": user_id, \"check_id\": "
"check.check_id, \"url\": check.bot_check_url})\n"
"        except CryptoBotError as exc:\n"
"            results.append({\"user_id\": user_id, \"error\": "
"f\"{exc.code}: {exc.name}\"})\n"
"    return results\n"
"\n"
"\n"
"def check_activations(client: CryptoBotClient, asset: Asset = "
"Asset.USDT):\n"
"    \"\"\"Report activated vs active checks.\"\"\"\n"
"    checks = client.get_checks(asset=asset)\n"
"    activated = [c for c in checks if c.activated_at is not None]\n"
"    pending = [c for c in checks if c.activated_at is None]\n"
"    return {\"activated\": len(activated), \"pending\": len(pending), "
"\"total\": len(checks)}\n"
"\n"
"\n"
"# Usage\n"
"recipients = [111111, 222222, 333333]\n"
"drops = airdrop_checks(client, recipients, amount=0.5, asset=Asset.TON)\n"
"for drop in drops:\n"
"    print(drop)\n"
"\n"
"print(\"Status:\", check_activations(client, Asset.TON))\n"
msgstr ""
"from cryptobot.models import Asset\n"
"\n"
"\n"
"def airdrop_checks(client: CryptoBotClient, user_ids: list, amount: "
"float, asset: Asset = Asset.USDT):\n"
"    \"\"\"Crear checks fijados para una lista de usuarios.\"\"\"\n"
"    results = []\n"
"    for user_id in user_ids:\n"
"        try:\n"
"            check = client.create_check(\n"
"                asset=asset,\n"
"                amount=amount,\n"
"                pin_to_user_id=user_id,\n"
"            )\n"
"            results.append({\"user_id\": user_id, \"check_id\": "
"check.check_id, \"url\": check.bot_check_url})\n"
"        except CryptoBotError as exc:\n"
"            results.append({\"user_id\": user_id, \"error\": "
"f\"{exc.code}: {exc.name}\"})\n"
"    return results\n"
"\n"
"\n"
"def check_activations(client: CryptoBotClient, asset: Asset = "
"Asset.USDT):\n"
"    \"\"\"Reportar checks activados vs activos.\"\"\"\n"
"    checks = client.get_checks(asset=asset)\n"
"    activated = [c for c in checks if c.activated_at is not None]\n"
"    pending = [c for c in checks if c.activated_at is None]\n"
"    return {\"activated\": len(activated), \"pending\": len(pending), "
"\"total\": len(checks)}\n"
"\n"
"\n"
"# Uso\n"
"recipients = [111111, 222222, 333333]\n"
"drops = airdrop_checks(client, recipients, amount=0.5, asset=Asset.TON)\n"
"for drop in drops:\n"
"    print(drop)\n"
"\n"
"print(\"Status:\", check_activations(client, Asset.TON))\n"

#: ../../examples.md:262
msgid "App Stats Dashboard"
msgstr "Panel de Estadísticas de la Aplicación"

#: ../../examples.md:264
msgid "Pull statistics and display a summary report."
msgstr "Obtenga estadísticas y muestre un informe resumido."

#: ../../examples.md:266
#, python-brace-format
msgid ""
"def stats_report(client: CryptoBotClient, start_at: str = None, end_at: "
"str = None):\n"
"    \"\"\"Print a summary of app statistics.\"\"\"\n"
"    stats = client.get_stats(start_at=start_at, end_at=end_at)\n"
"    print(f\"Volume:           {stats.volume}\")\n"
"    print(f\"Conversion:       {stats.conversion}\")\n"
"    print(f\"Unique users:     {stats.unique_users_count}\")\n"
"    print(f\"Invoices created: {stats.created_invoice_count}\")\n"
"    print(f\"Invoices paid:    {stats.paid_invoice_count}\")\n"
"    print(f\"Period:           {stats.start_at} to {stats.end_at}\")\n"
"\n"
"\n"
"# Last 7 days\n"
"stats_report(client, start_at=\"2026-03-11T00:00:00Z\", "
"end_at=\"2026-03-18T00:00:00Z\")\n"
msgstr ""
"def stats_report(client: CryptoBotClient, start_at: str = None, end_at: "
"str = None):\n"
"    \"\"\"Imprimir un resumen de estadísticas de la aplicación.\"\"\"\n"
"    stats = client.get_stats(start_at=start_at, end_at=end_at)\n"
"    print(f\"Volume:           {stats.volume}\")\n"
"    print(f\"Conversion:       {stats.conversion}\")\n"
"    print(f\"Unique users:     {stats.unique_users_count}\")\n"
"    print(f\"Invoices created: {stats.created_invoice_count}\")\n"
"    print(f\"Invoices paid:    {stats.paid_invoice_count}\")\n"
"    print(f\"Period:           {stats.start_at} to {stats.end_at}\")\n"
"\n"
"\n"
"# Últimos 7 días\n"
"stats_report(client, start_at=\"2026-03-11T00:00:00Z\", "
"end_at=\"2026-03-18T00:00:00Z\")\n"

#: ../../examples.md:282
msgid "Transfer Ledger"
msgstr "Libro Mayor de Transferencias"

#: ../../examples.md:284
msgid "Scan outgoing transfers and build a local ledger."
msgstr "Escanee las transferencias salientes y construya un libro mayor local."

#: ../../examples.md:286
#, python-brace-format
msgid ""
"from decimal import Decimal\n"
"\n"
"\n"
"def transfer_ledger(client: CryptoBotClient, asset: Asset = None):\n"
"    \"\"\"Build a ledger of all outgoing transfers.\"\"\"\n"
"    ledger = []\n"
"    for transfer in client.iter_transfers(asset=asset, page_size=200):\n"
"        ledger.append({\n"
"            \"id\": transfer.transfer_id,\n"
"            \"user_id\": transfer.user_id,\n"
"            \"asset\": transfer.asset.name,\n"
"            \"amount\": transfer.amount,\n"
"            \"status\": transfer.status.name,\n"
"            \"spend_id\": transfer.spend_id,\n"
"            \"completed_at\": transfer.completed_at,\n"
"        })\n"
"\n"
"    total = sum(Decimal(str(t[\"amount\"])) for t in ledger)\n"
"    return {\"entries\": ledger, \"total\": str(total), \"count\": "
"len(ledger)}\n"
"\n"
"\n"
"result = transfer_ledger(client, asset=Asset.TON)\n"
"print(f\"Total transferred: {result['total']} ({result['count']} "
"transfers)\")\n"
