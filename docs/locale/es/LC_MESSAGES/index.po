#: ../../index.md:1
msgid "Welcome to CryptoBot Python"
msgstr "Bienvenido a CryptoBot Python"

#: ../../index.md:3
msgid ""
"CryptoBot Python is an unofficial, friendly client library for the "
"[Crypto Bot](https://pay.crypt.bot/) API. It provides typed models and "
"synchronous/async clients for invoices, transfers, checks, balances, "
"exchange rates, statistics, and webhook handling."
msgstr ""
"CryptoBot Python es una biblioteca cliente no oficial y amigable para la "
"API de [Crypto Bot](https://pay.crypt.bot/). Proporciona modelos tipados y "
"clientes síncronos/asíncronos para facturas, transferencias, checks, saldos, "
"tasas de cambio, estadísticas y manejo de webhooks."

#: ../../index.md:6
msgid "Highlights"
msgstr "Características Destacadas"

#: ../../index.md:8
msgid "Synchronous API client built on `httpx`"
msgstr "Cliente de API síncrono construido sobre `httpx`"

#: ../../index.md:9
msgid "Async API client built on `httpx`"
msgstr "Cliente de API asíncrono construido sobre `httpx`"

#: ../../index.md:10
msgid ""
"Dataclass response models (`Invoice`, `Transfer`, `Check`, `Balance`, "
"`ExchangeRate`, `Currency`, `AppStats`)"
msgstr ""
"Modelos de respuesta dataclass (`Invoice`, `Transfer`, `Check`, `Balance`, "
"`ExchangeRate`, `Currency`, `AppStats`)"

#: ../../index.md:11
msgid "Enum safety for assets, statuses, check statuses, and paid button names"
msgstr "Seguridad basada en Enum para activos, estados, estados de checks y nombres de botones"

#: ../../index.md:12
msgid "Mainnet/testnet support with configurable timeout and retries"
msgstr "Soporte de mainnet/testnet con timeout y reintentos configurables"

#: ../../index.md:13
msgid "Pagination iterators for invoices, transfers, and checks"
msgstr "Iteradores de paginación para facturas, transferencias y checks"

#: ../../index.md:14
msgid ""
"FastAPI webhook listener with signature verification and optional replay "
"protection"
msgstr ""
"Listener de webhook FastAPI con verificación de firma y protección opcional "
"contra repetición"

#: ../../index.md:15
msgid "Structured API errors via `CryptoBotError` (`code`, `name`)"
msgstr "Errores de API estructurados a través de `CryptoBotError` (`code`, `name`)"

#: ../../index.md:17
msgid "Quick Example"
msgstr "Ejemplo Rápido"

#: ../../index.md:19
msgid ""
"import os\n"
"\n"
"from cryptobot import CryptoBotClient\n"
"from cryptobot.models import Asset\n"
"\n"
"client = CryptoBotClient(api_token=os.environ[\"CRYPTOBOT_API_TOKEN\"])\n"
"\n"
"app = client.get_me()\n"
"print(app.name)\n"
"\n"
"invoice = client.create_invoice(\n"
"    asset=Asset.USDT,\n"
"    amount=5.25,\n"
"    description=\"Coffee order #42\",\n"
")\n"
"print(invoice.invoice_id, invoice.bot_invoice_url)\n"
msgstr ""
"import os\n"
"\n"
"from cryptobot import CryptoBotClient\n"
"from cryptobot.models import Asset\n"
"\n"
"client = CryptoBotClient(api_token=os.environ[\"CRYPTOBOT_API_TOKEN\"])\n"
"\n"
"app = client.get_me()\n"
"print(app.name)\n"
"\n"
"invoice = client.create_invoice(\n"
"    asset=Asset.USDT,\n"
"    amount=5.25,\n"
"    description=\"Coffee order #42\",\n"
")\n"
"print(invoice.invoice_id, invoice.bot_invoice_url)\n"

