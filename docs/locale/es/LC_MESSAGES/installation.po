#: ../../installation.md:1
msgid "Installation"
msgstr "Instalación"

#: ../../installation.md:3
msgid "Requirements"
msgstr "Requisitos"

#: ../../installation.md:5
msgid "Python 3.10+"
msgstr "Python 3.10+"

#: ../../installation.md:6
msgid "pip (or [uv](https://docs.astral.sh/uv/) for development)"
msgstr "pip (o [uv](https://docs.astral.sh/uv/) para desarrollo)"

#: ../../installation.md:8
msgid "Install from PyPI"
msgstr "Instalar desde PyPI"

#: ../../installation.md:10
msgid "pip install cryptobot-python\n"
msgstr "pip install cryptobot-python\n"

#: ../../installation.md:14
msgid "Install optional extras only when needed:"
msgstr "Instale los extras opcionales solo cuando sea necesario:"

#: ../../installation.md:16
msgid ""
"pip install \"cryptobot-python[webhook]\"\n"
"pip install \"cryptobot-python[docs]\"\n"
msgstr ""
"pip install \"cryptobot-python[webhook]\"\n"
"pip install \"cryptobot-python[docs]\"\n"

#: ../../installation.md:21
msgid "Verify Installation"
msgstr "Verificar la Instalación"

#: ../../installation.md:23
msgid ""
"from cryptobot import CryptoBotClient\n"
"print(CryptoBotClient)\n"
msgstr ""
"from cryptobot import CryptoBotClient\n"
"print(CryptoBotClient)\n"

#: ../../installation.md:28
msgid "Install from Source"
msgstr "Instalar desde las Fuentes"

#: ../../installation.md:30
msgid ""
"git clone https://github.com/ragnarok22/cryptobot_python.git\n"
"cd cryptobot_python\n"
"uv sync\n"
msgstr ""
"git clone https://github.com/ragnarok22/cryptobot_python.git\n"
"cd cryptobot_python\n"
"uv sync\n"

#: ../../installation.md:36
msgid "For documentation tooling:"
msgstr "Para herramientas de documentación:"

#: ../../installation.md:38
msgid "uv sync --extra docs\n"
msgstr "uv sync --extra docs\n"

#: ../../installation.md:42
msgid "For local webhook development with FastAPI/Uvicorn:"
msgstr "Para desarrollo local de webhooks con FastAPI/Uvicorn:"

#: ../../installation.md:44
msgid "uv sync --extra webhook\n"
msgstr "uv sync --extra webhook\n"

#: ../../installation.md:48
msgid "Development Setup"
msgstr "Configuración de Desarrollo"

#: ../../installation.md:50
msgid ""
"uv sync\n"
"make lint\n"
"make test\n"
msgstr ""
"uv sync\n"
"make lint\n"
"make test\n"

#: ../../installation.md:56
msgid "Common Pitfalls"
msgstr "Errores Comunes"

#: ../../installation.md:58
msgid "Use `cryptobot-python` as the package name in `pip install`."
msgstr "Use `cryptobot-python` como nombre del paquete en `pip install`."

#: ../../installation.md:59
msgid "Keep mainnet and testnet tokens separate."
msgstr "Mantenga los tokens de mainnet y testnet separados."

#: ../../installation.md:60
msgid "Store tokens in environment variables instead of source code."
msgstr "Almacene los tokens en variables de entorno en lugar de en el código fuente."

