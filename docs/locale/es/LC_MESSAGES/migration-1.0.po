#: ../../migration-1.0.md:88
msgid "`get_stats(start_at, end_at)`"
msgstr "`get_stats(start_at, end_at)`"

#: ../../migration-1.0.md:89
msgid "`fiat` filter parameter on `get_invoices()`"
msgstr "Parámetro de filtro `fiat` en `get_invoices()`"

#: ../../migration-1.0.md:91
msgid ""
"All new endpoints are available on both `CryptoBotClient` and "
