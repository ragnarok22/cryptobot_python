#: ../../troubleshooting.md:252
msgid "Testnet Smoke Test"
msgstr "Prueba Rápida de Testnet"

#: ../../troubleshooting.md:254
msgid ""
"import os\n"
"\n"
"from cryptobot import CryptoBotClient\n"
"from cryptobot.models import Asset\n"
"\n"
"\n"
"def smoke_test() -> bool:\n"
"    client = CryptoBotClient(\n"
"        api_token=os.environ[\"CRYPTOBOT_TESTNET_TOKEN\"],\n"
"        is_mainnet=False,\n"
"    )\n"
"\n"
"    try:\n"
"        client.get_me()\n"
"        client.get_balances()\n"
"        client.get_exchange_rates()\n"
"        client.create_invoice(asset=Asset.USDT, amount=1, "
"description=\"smoke\")\n"
"        return True\n"
"    except Exception:\n"
"        return False\n"
msgstr ""
