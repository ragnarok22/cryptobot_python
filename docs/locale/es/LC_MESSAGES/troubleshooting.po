#: ../../troubleshooting.md:53
msgid "Validate amount before API calls:"
msgstr "Valide el monto antes de las llamadas a la API:"

#: ../../troubleshooting.md:55
#, python-brace-format
msgid ""
"from decimal import Decimal\n"
"\n"
"from cryptobot.models import Asset\n"
"\n"
"\n"
"MIN_AMOUNTS = {\n"
"    Asset.USDT: Decimal(\"0.01\"),\n"
"    Asset.USDC: Decimal(\"0.01\"),\n"
"    Asset.TON: Decimal(\"0.01\"),\n"
"    Asset.BTC: Decimal(\"0.000001\"),\n"
"}\n"
"\n"
"\n"
"def validate_amount(asset: Asset, amount: float):\n"
"    value = Decimal(str(amount))\n"
"    minimum = MIN_AMOUNTS.get(asset)\n"
"    if minimum is not None and value < minimum:\n"
"        raise ValueError(f\"Amount too small for {asset.name}. Minimum is"
" {minimum}\")\n"
msgstr ""
"from decimal import Decimal\n"
"\n"
"from cryptobot.models import Asset\n"
"\n"
"\n"
"MIN_AMOUNTS = {\n"
"    Asset.USDT: Decimal(\"0.01\"),\n"
"    Asset.USDC: Decimal(\"0.01\"),\n"
"    Asset.TON: Decimal(\"0.01\"),\n"
"    Asset.BTC: Decimal(\"0.000001\"),\n"
"}\n"
"\n"
"\n"
"def validate_amount(asset: Asset, amount: float):\n"
"    value = Decimal(str(amount))\n"
"    minimum = MIN_AMOUNTS.get(asset)\n"
"    if minimum is not None and value < minimum:\n"
"        raise ValueError(f\"Amount too small for {asset.name}. Minimum is"
" {minimum}\")\n"

#: ../../troubleshooting.md:76
msgid "Invoice Status Not Updating"
msgstr "El Estado de la Factura No se Actualiza"

