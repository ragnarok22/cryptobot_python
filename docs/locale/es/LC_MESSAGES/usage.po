#: ../../usage.md:1
msgid "Usage"
msgstr "Uso"

#: ../../usage.md:3
msgid "Quick Start"
msgstr "Inicio Rápido"

#: ../../usage.md:5
msgid "Import the client, core models, and error types:"
msgstr "Importe el cliente, los modelos principales y los tipos de error:"

#: ../../usage.md:7
msgid ""
"import os\n"
"\n"
"from cryptobot import CryptoBotClient\n"
"from cryptobot.errors import CryptoBotError\n"
"from cryptobot.models import Asset, ButtonName, Status\n"
msgstr ""
"import os\n"
"\n"
"from cryptobot import CryptoBotClient\n"
"from cryptobot.errors import CryptoBotError\n"
"from cryptobot.models import Asset, ButtonName, Status\n"

#: ../../usage.md:15
msgid "Create a client instance with your API token:"
msgstr "Cree una instancia del cliente con su token de API:"

#: ../../usage.md:17
msgid ""
"client = CryptoBotClient(\n"
"    api_token=os.environ[\"CRYPTOBOT_API_TOKEN\"],\n"
"    is_mainnet=True,\n"
"    timeout=5.0,\n"
")\n"
msgstr ""
"client = CryptoBotClient(\n"
"    api_token=os.environ[\"CRYPTOBOT_API_TOKEN\"],\n"
"    is_mainnet=True,\n"
"    timeout=5.0,\n"
")\n"

#: ../../usage.md:25
msgid "Async quick start:"
msgstr "Inicio rápido asíncrono:"

#: ../../usage.md:27
msgid ""
"from cryptobot import AsyncCryptoBotClient\n"
"\n"
"\n"
"async def run():\n"
"    async with "
"AsyncCryptoBotClient(api_token=os.environ[\"CRYPTOBOT_API_TOKEN\"], "
"max_retries=2) as client:\n"
"        app = await client.get_me()\n"
"        print(app.name)\n"
msgstr ""
"from cryptobot import AsyncCryptoBotClient\n"
"\n"
"\n"
"async def run():\n"
"    async with "
"AsyncCryptoBotClient(api_token=os.environ[\"CRYPTOBOT_API_TOKEN\"], "
"max_retries=2) as client:\n"
"        app = await client.get_me()\n"
"        print(app.name)\n"

#: ../../usage.md:37
msgid "Basic Operations"
msgstr "Operaciones Básicas"

#: ../../usage.md:39
msgid "Getting App Information"
msgstr "Obtener Información de la Aplicación"

#: ../../usage.md:41
msgid "Get basic information about your app:"
msgstr "Obtenga información básica sobre su aplicación:"

#: ../../usage.md:43
#, python-brace-format
msgid ""
"app = client.get_me()\n"
"print(f\"App ID: {app.app_id}\")\n"
"print(f\"App Name: {app.name}\")\n"
"print(f\"Bot Username: {app.payment_processing_bot_username}\")\n"
msgstr ""
"app = client.get_me()\n"
"print(f\"App ID: {app.app_id}\")\n"
"print(f\"App Name: {app.name}\")\n"
"print(f\"Bot Username: {app.payment_processing_bot_username}\")\n"

#: ../../usage.md:50
msgid "Creating an Invoice"
msgstr "Crear una Factura"

#: ../../usage.md:52
msgid "Create a simple invoice for cryptocurrency payment:"
msgstr "Cree una factura simple para pago en criptomoneda:"

#: ../../usage.md:54
#, python-brace-format
msgid ""
"invoice = client.create_invoice(\n"
"    asset=Asset.USDT,\n"
"    amount=5.25,\n"
"    description=\"Coffee order #42\"\n"
")\n"
"\n"
"print(f\"Invoice URL: {invoice.bot_invoice_url}\")\n"
"print(f\"Invoice ID: {invoice.invoice_id}\")\n"
msgstr ""
"invoice = client.create_invoice(\n"
"    asset=Asset.USDT,\n"
"    amount=5.25,\n"
"    description=\"Coffee order #42\"\n"
")\n"
"\n"
"print(f\"Invoice URL: {invoice.bot_invoice_url}\")\n"
"print(f\"Invoice ID: {invoice.invoice_id}\")\n"

#: ../../usage.md:65
msgid "Creating an Invoice with Custom Options"
msgstr "Crear una Factura con Opciones Personalizadas"

#: ../../usage.md:67
msgid "Create an invoice with additional parameters:"
msgstr "Cree una factura con parámetros adicionales:"

#: ../../usage.md:69
msgid ""
"invoice = client.create_invoice(\n"
"    asset=Asset.BTC,\n"
"    amount=0.001,\n"
"    description=\"Premium service subscription\",\n"
"    paid_btn_name=ButtonName.callback,  # Enum value for paid invoice "
"button\n"
"    paid_btn_url=\"https://example.com/success\",  # URL for success "
"callback\n"
"    payload=\"user_123_premium\",  # Custom payload for tracking\n"
"    allow_comments=True,  # Allow user comments\n"
"    allow_anonymous=False,  # Require user identification\n"
"    expires_in=3600  # Expire after 1 hour\n"
")\n"
msgstr ""
"invoice = client.create_invoice(\n"
"    asset=Asset.BTC,\n"
"    amount=0.001,\n"
"    description=\"Premium service subscription\",\n"
"    paid_btn_name=ButtonName.callback,  # Valor Enum para botón de factura pagada\n"
"    paid_btn_url=\"https://example.com/success\",  # URL para callback de éxito\n"
"    payload=\"user_123_premium\",  # Payload personalizado para seguimiento\n"
"    allow_comments=True,  # Permitir comentarios del usuario\n"
"    allow_anonymous=False,  # Requerir identificación del usuario\n"
"    expires_in=3600  # Expirar después de 1 hora\n"
")\n"

#: ../../usage.md:83
msgid "Making Transfers"
msgstr "Realizar Transferencias"

#: ../../usage.md:85
msgid "Transfer cryptocurrency to another user:"
msgstr "Transfiera criptomoneda a otro usuario:"

#: ../../usage.md:87
#, python-brace-format
msgid ""
"try:\n"
"    transfer = client.transfer(\n"
"        user_id=12345,\n"
"        asset=Asset.TON,\n"
"        amount=0.5,\n"
"        spend_id=\"transfer_001\",  # Unique spend ID to prevent "
"duplicates\n"
"        comment=\"Payment for services\"\n"
"    )\n"
"    print(f\"Transfer completed: {transfer.transfer_id}\")\n"
"except CryptoBotError as e:\n"
"    print(f\"Transfer failed: {e.code} - {e.name}\")\n"
msgstr ""
"try:\n"
"    transfer = client.transfer(\n"
"        user_id=12345,\n"
"        asset=Asset.TON,\n"
"        amount=0.5,\n"
"        spend_id=\"transfer_001\",  # ID único de gasto para prevenir "
"duplicados\n"
"        comment=\"Payment for services\"\n"
"    )\n"
"    print(f\"Transfer completed: {transfer.transfer_id}\")\n"
"except CryptoBotError as e:\n"
"    print(f\"Transfer failed: {e.code} - {e.name}\")\n"

#: ../../usage.md:101
msgid "Checking Balances"
msgstr "Consultar Saldos"

#: ../../usage.md:103
msgid "Get your current balances:"
msgstr "Obtenga sus saldos actuales:"

#: ../../usage.md:105
#, python-brace-format
msgid ""
"balances = client.get_balances()\n"
"for balance in balances:\n"
"    print(f\"{balance.currency_code}: {balance.available}\")\n"
msgstr ""
"balances = client.get_balances()\n"
"for balance in balances:\n"
"    print(f\"{balance.currency_code}: {balance.available}\")\n"

#: ../../usage.md:111
msgid "Getting Exchange Rates"
msgstr "Obtener Tasas de Cambio"

#: ../../usage.md:113
msgid "Retrieve current exchange rates:"
msgstr "Obtenga las tasas de cambio actuales:"

#: ../../usage.md:115
#, python-brace-format
msgid ""
"rates = client.get_exchange_rates()\n"
"for rate in rates:\n"
"    print(f\"1 {rate.source} = {rate.rate} {rate.target}\")\n"
msgstr ""
"rates = client.get_exchange_rates()\n"
"for rate in rates:\n"
"    print(f\"1 {rate.source} = {rate.rate} {rate.target}\")\n"

#: ../../usage.md:121
msgid "You can also filter for specific currencies:"
msgstr "También puede filtrar por monedas específicas:"

#: ../../usage.md:123
#, python-brace-format
msgid ""
"# Find USD exchange rate for Bitcoin\n"
"btc_usd_rate = next((r for r in rates if r.source == \"BTC\" and r.target"
" == \"USD\"), None)\n"
"if btc_usd_rate:\n"
"    print(f\"1 BTC = ${btc_usd_rate.rate} USD\")\n"
msgstr ""
"# Encontrar la tasa de cambio USD para Bitcoin\n"
"btc_usd_rate = next((r for r in rates if r.source == \"BTC\" and r.target"
" == \"USD\"), None)\n"
"if btc_usd_rate:\n"
"    print(f\"1 BTC = ${btc_usd_rate.rate} USD\")\n"

#: ../../usage.md:130
msgid "Getting Supported Currencies"
msgstr "Obtener Monedas Soportadas"

#: ../../usage.md:132
msgid "Get information about all supported currencies:"
msgstr "Obtenga información sobre todas las monedas soportadas:"

#: ../../usage.md:134
#, python-brace-format
msgid ""
"currencies = client.get_currencies()\n"
"for currency in currencies:\n"
"    print(f\"{currency.name} ({currency.code})\")\n"
"    print(f\"  Blockchain: {currency.is_blockchain}\")\n"
"    print(f\"  Stablecoin: {currency.is_stablecoin}\")\n"
"    print(f\"  Decimals: {currency.decimals}\")\n"
"    if currency.url:\n"
"        print(f\"  URL: {currency.url}\")\n"
msgstr ""
"currencies = client.get_currencies()\n"
"for currency in currencies:\n"
"    print(f\"{currency.name} ({currency.code})\")\n"
"    print(f\"  Blockchain: {currency.is_blockchain}\")\n"
"    print(f\"  Stablecoin: {currency.is_stablecoin}\")\n"
"    print(f\"  Decimals: {currency.decimals}\")\n"
"    if currency.url:\n"
"        print(f\"  URL: {currency.url}\")\n"

#: ../../usage.md:145
msgid "Filter by type:"
msgstr "Filtrar por tipo:"

#: ../../usage.md:147
msgid ""
"# Get only blockchain currencies\n"
"blockchain_currencies = [c for c in currencies if c.is_blockchain]\n"
"\n"
"# Get only stablecoins\n"
"stablecoins = [c for c in currencies if c.is_stablecoin]\n"
"\n"
"# Get only fiat currencies\n"
"fiat_currencies = [c for c in currencies if c.is_fiat]\n"
msgstr ""
"# Obtener solo monedas blockchain\n"
"blockchain_currencies = [c for c in currencies if c.is_blockchain]\n"
"\n"
"# Obtener solo stablecoins\n"
"stablecoins = [c for c in currencies if c.is_stablecoin]\n"
"\n"
"# Obtener solo monedas fiat\n"
"fiat_currencies = [c for c in currencies if c.is_fiat]\n"

#: ../../usage.md:158
msgid "Getting Invoice Information"
msgstr "Obtener Información de Facturas"

#: ../../usage.md:160
msgid "Retrieve information about existing invoices:"
msgstr "Obtenga información sobre facturas existentes:"

#: ../../usage.md:162
msgid ""
"# Get all invoices\n"
"invoices = client.get_invoices()\n"
"\n"
"# Get invoices with filters\n"
"paid_invoices = client.get_invoices(\n"
"    asset=Asset.USDT,\n"
"    invoice_ids=[123, 456],\n"
"    status=Status.paid,\n"
"    offset=0,\n"
"    count=50\n"
")\n"
msgstr ""
"# Obtener todas las facturas\n"
"invoices = client.get_invoices()\n"
"\n"
"# Obtener facturas con filtros\n"
"paid_invoices = client.get_invoices(\n"
"    asset=Asset.USDT,\n"
"    invoice_ids=[123, 456],\n"
"    status=Status.paid,\n"
"    offset=0,\n"
"    count=50\n"
")\n"

#: ../../usage.md:176
msgid ""
"`invoice_ids` accepts either a comma-separated string (`\"123,456\"`) or "
"`list[int]` (`[123, 456]`). `count` is validated between `1` and `1000`."
msgstr ""
"`invoice_ids` acepta una cadena separada por comas (`\"123,456\"`) o "
"`list[int]` (`[123, 456]`). `count` se valida entre `1` y `1000`."

#: ../../usage.md:179
msgid "Async equivalent:"
msgstr "Equivalente asíncrono:"

#: ../../usage.md:181
msgid ""
"import os\n"
"\n"
"from cryptobot import AsyncCryptoBotClient\n"
"from cryptobot.models import Asset, Status\n"
"\n"
"async with "
"AsyncCryptoBotClient(api_token=os.environ[\"CRYPTOBOT_API_TOKEN\"]) as "
"async_client:\n"
"    paid_invoices = await async_client.get_invoices(\n"
"        asset=Asset.USDT,\n"
"        invoice_ids=[123, 456],\n"
"        status=Status.paid,\n"
"        count=50,\n"
"    )\n"
msgstr ""
"import os\n"
"\n"
"from cryptobot import AsyncCryptoBotClient\n"
"from cryptobot.models import Asset, Status\n"
"\n"
"async with "
"AsyncCryptoBotClient(api_token=os.environ[\"CRYPTOBOT_API_TOKEN\"]) as "
"async_client:\n"
"    paid_invoices = await async_client.get_invoices(\n"
"        asset=Asset.USDT,\n"
"        invoice_ids=[123, 456],\n"
"        status=Status.paid,\n"
"        count=50,\n"
"    )\n"

#: ../../usage.md:196
msgid "Deleting an Invoice"
msgstr "Eliminar una Factura"

#: ../../usage.md:198
msgid "Delete an active invoice that is no longer needed:"
msgstr "Elimine una factura activa que ya no sea necesaria:"

#: ../../usage.md:200
msgid ""
"deleted = client.delete_invoice(invoice_id=12345)\n"
"print(\"Deleted:\", deleted)\n"
msgstr ""
"deleted = client.delete_invoice(invoice_id=12345)\n"
"print(\"Deleted:\", deleted)\n"

#: ../../usage.md:205
msgid "Retrieving Transfers"
msgstr "Obtener Transferencias"

#: ../../usage.md:207
msgid "List outgoing transfers with optional filters:"
msgstr "Liste las transferencias salientes con filtros opcionales:"

#: ../../usage.md:209
msgid ""
"# Get all transfers\n"
"transfers = client.get_transfers()\n"
"\n"
"# Filter by asset or specific IDs\n"
"transfers = client.get_transfers(asset=Asset.TON, count=50)\n"
"transfers = client.get_transfers(transfer_ids=[100, 101, 102])\n"
"\n"
"# Look up by spend_id\n"
"transfers = "
"client.get_transfers(spend_id=\"reward_2026_02_10_user_123456789\")\n"
msgstr ""
"# Obtener todas las transferencias\n"
"transfers = client.get_transfers()\n"
"\n"
"# Filtrar por activo o IDs específicos\n"
"transfers = client.get_transfers(asset=Asset.TON, count=50)\n"
"transfers = client.get_transfers(transfer_ids=[100, 101, 102])\n"
"\n"
"# Buscar por spend_id\n"
"transfers = "
"client.get_transfers(spend_id=\"reward_2026_02_10_user_123456789\")\n"

#: ../../usage.md:221
msgid "Crypto Checks"
msgstr "Checks Criptográficos"

#: ../../usage.md:223
msgid "Create a check that any Telegram user (or a pinned user) can activate:"
msgstr "Cree un check que cualquier usuario de Telegram (o un usuario fijado) pueda activar:"

#: ../../usage.md:225
msgid ""
"from cryptobot.models import Asset\n"
"\n"
"# Create an open check\n"
"check = client.create_check(asset=Asset.USDT, amount=1.0)\n"
"print(check.check_id, check.bot_check_url)\n"
"\n"
"# Pin a check to a specific user\n"
"check = client.create_check(asset=Asset.TON, amount=0.25, "
"pin_to_user_id=123456789)\n"
msgstr ""
"from cryptobot.models import Asset\n"
"\n"
"# Crear un check abierto\n"
"check = client.create_check(asset=Asset.USDT, amount=1.0)\n"
"print(check.check_id, check.bot_check_url)\n"
"\n"
"# Fijar un check a un usuario específico\n"
"check = client.create_check(asset=Asset.TON, amount=0.25, "
"pin_to_user_id=123456789)\n"

#: ../../usage.md:236
msgid "Retrieve and manage checks:"
msgstr "Obtener y gestionar checks:"

#: ../../usage.md:238
msgid ""
"# List active checks\n"
"checks = client.get_checks(asset=Asset.USDT, status=\"active\")\n"
"\n"
"# Get specific checks by ID\n"
"checks = client.get_checks(check_ids=[10, 11, 12])\n"
"\n"
"# Delete a check\n"
"client.delete_check(check_id=checks[0].check_id)\n"
msgstr ""
"# Listar checks activos\n"
"checks = client.get_checks(asset=Asset.USDT, status=\"active\")\n"
"\n"
"# Obtener checks específicos por ID\n"
"checks = client.get_checks(check_ids=[10, 11, 12])\n"
"\n"
"# Eliminar un check\n"
"client.delete_check(check_id=checks[0].check_id)\n"

#: ../../usage.md:249
msgid "App Statistics"
msgstr "Estadísticas de la Aplicación"

#: ../../usage.md:251
msgid "Get aggregated statistics for your app:"
msgstr "Obtenga estadísticas agregadas para su aplicación:"

#: ../../usage.md:253
#, python-brace-format
msgid ""
"stats = client.get_stats(\n"
"    start_at=\"2026-01-01T00:00:00Z\",\n"
"    end_at=\"2026-03-01T00:00:00Z\",\n"
")\n"
"print(f\"Volume: {stats.volume}\")\n"
"print(f\"Unique users: {stats.unique_users_count}\")\n"
"print(f\"Paid invoices: {stats.paid_invoice_count}\")\n"
"print(f\"Conversion: {stats.conversion}\")\n"
msgstr ""
"stats = client.get_stats(\n"
"    start_at=\"2026-01-01T00:00:00Z\",\n"
"    end_at=\"2026-03-01T00:00:00Z\",\n"
")\n"
"print(f\"Volume: {stats.volume}\")\n"
"print(f\"Unique users: {stats.unique_users_count}\")\n"
"print(f\"Paid invoices: {stats.paid_invoice_count}\")\n"
"print(f\"Conversion: {stats.conversion}\")\n"

#: ../../usage.md:264
msgid ""
"Both `start_at` and `end_at` are optional ISO 8601 strings. When omitted,"
" `start_at` defaults to 24 hours ago and `end_at` defaults to now."
msgstr ""
"Tanto `start_at` como `end_at` son cadenas ISO 8601 opcionales. Cuando se "
"omiten, `start_at` toma por defecto las últimas 24 horas y `end_at` toma "
"por defecto el momento actual."

#: ../../usage.md:266
msgid "Environment Configuration"
msgstr "Configuración del Entorno"

#: ../../usage.md:268
msgid "Testnet vs Mainnet"
msgstr "Testnet vs Mainnet"

#: ../../usage.md:270
msgid ""
"By default, the client uses the mainnet environment. To target the "
"testnet (with a testnet token), set `is_mainnet=False`:"
msgstr ""
"Por defecto, el cliente usa el entorno mainnet. Para usar testnet "
"(con un token de testnet), establezca `is_mainnet=False`:"

#: ../../usage.md:272
msgid ""
"client = CryptoBotClient(os.environ[\"CRYPTOBOT_TESTNET_TOKEN\"], "
"is_mainnet=False)\n"
msgstr ""
"client = CryptoBotClient(os.environ[\"CRYPTOBOT_TESTNET_TOKEN\"], "
"is_mainnet=False)\n"

#: ../../usage.md:276
msgid "Custom Timeout"
msgstr "Timeout Personalizado"

#: ../../usage.md:278
msgid "Configure request timeout (default is 5 seconds):"
msgstr "Configure el timeout de solicitudes (por defecto son 5 segundos):"

#: ../../usage.md:280
msgid ""
"client = CryptoBotClient(os.environ[\"CRYPTOBOT_API_TOKEN\"], timeout=60)"
"\n"
msgstr ""
"client = CryptoBotClient(os.environ[\"CRYPTOBOT_API_TOKEN\"], timeout=60)"
"\n"

#: ../../usage.md:284
msgid "Built-in Retries"
msgstr "Reintentos Integrados"

#: ../../usage.md:286
msgid "Retry behavior is optional and disabled by default (`max_retries=0`)."
msgstr "El comportamiento de reintentos es opcional y está deshabilitado por defecto (`max_retries=0`)."

#: ../../usage.md:288
#, python-brace-format
msgid ""
"client = CryptoBotClient(\n"
"    api_token=os.environ[\"CRYPTOBOT_API_TOKEN\"],\n"
"    timeout=30.0,\n"
"    max_retries=3,\n"
"    retry_backoff=0.5,\n"
"    retryable_status_codes={429, 500, 502, 503, 504},\n"
")\n"
msgstr ""
"client = CryptoBotClient(\n"
"    api_token=os.environ[\"CRYPTOBOT_API_TOKEN\"],\n"
"    timeout=30.0,\n"
"    max_retries=3,\n"
"    retry_backoff=0.5,\n"
"    retryable_status_codes={429, 500, 502, 503, 504},\n"
")\n"

#: ../../usage.md:298
msgid ""
"When present, the `Retry-After` response header is respected "
"automatically before the next attempt."
msgstr ""
"Cuando está presente, el encabezado de respuesta `Retry-After` se respeta "
"automáticamente antes del siguiente intento."

#: ../../usage.md:300
msgid "Swap Incoming Payments"
msgstr "Convertir Pagos Entrantes"

#: ../../usage.md:302
msgid "Automatically convert payments to a different asset by using `swap_to`:"
msgstr "Convierta automáticamente los pagos a un activo diferente usando `swap_to`:"

#: ../../usage.md:304
#, python-brace-format
msgid ""
"invoice = client.create_invoice(\n"
"    asset=Asset.TON,\n"
"    amount=20,\n"
"    description=\"Swap TON to USDT on receipt\",\n"
"    swap_to=\"USDT\",\n"
")\n"
"print(invoice.bot_invoice_url)\n"
msgstr ""
"invoice = client.create_invoice(\n"
"    asset=Asset.TON,\n"
"    amount=20,\n"
"    description=\"Swap TON to USDT on receipt\",\n"
"    swap_to=\"USDT\",\n"
")\n"
"print(invoice.bot_invoice_url)\n"

#: ../../usage.md:314
msgid "Error Handling"
msgstr "Manejo de Errores"

#: ../../usage.md:316
#, python-brace-format
msgid "All API errors raise {class}`cryptobot.errors.CryptoBotError`:"
msgstr ""
"Todos los errores de la API lanzan "
"{class}`cryptobot.errors.CryptoBotError`:"

#: ../../usage.md:318
#, python-brace-format
msgid ""
"from cryptobot.errors import CryptoBotError\n"
"\n"
"try:\n"
"    client.transfer(user_id=12345, asset=Asset.BTC, amount=10, "
"spend_id=\"test\")\n"
"except CryptoBotError as exc:\n"
"    print(f\"Error code: {exc.code}\")\n"
"    print(f\"Error name: {exc.name}\")\n"
msgstr ""
"from cryptobot.errors import CryptoBotError\n"
"\n"
"try:\n"
"    client.transfer(user_id=12345, asset=Asset.BTC, amount=10, "
"spend_id=\"test\")\n"
"except CryptoBotError as exc:\n"
"    print(f\"Error code: {exc.code}\")\n"
"    print(f\"Error name: {exc.name}\")\n"

#: ../../usage.md:328
msgid "Webhook Integration"
msgstr "Integración de Webhook"

#: ../../usage.md:330
msgid "Using the Built-in Webhook Server"
msgstr "Usar el Servidor Webhook Integrado"

#: ../../usage.md:332
msgid ""
"CryptoBot Python includes a FastAPI-based webhook listener for handling "
"payment notifications:"
msgstr ""
"CryptoBot Python incluye un listener de webhook basado en FastAPI para "
"manejar notificaciones de pago:"

#: ../../usage.md:334
#, python-brace-format
msgid ""
"import os\n"
"\n"
"from cryptobot.webhook import InMemoryReplayKeyStore, Listener\n"
"\n"
"\n"
"def handle_webhook(headers, data):\n"
"    if data.get(\"update_type\") == \"invoice_paid\":\n"
"        payload = data.get(\"payload\", {})\n"
"        print(\"Paid invoice:\", payload.get(\"invoice_id\"))\n"
"\n"
"\n"
"listener = Listener(\n"
"    host=\"0.0.0.0\",\n"
"    callback=handle_webhook,\n"
"    api_token=os.environ[\"CRYPTOBOT_API_TOKEN\"],\n"
"    replay_store=InMemoryReplayKeyStore(),\n"
"    replay_ttl_seconds=3600,\n"
"    port=2203,\n"
"    url=\"/webhook\",\n"
"    log_level=\"info\",\n"
")\n"
"listener.listen()\n"
msgstr ""
"import os\n"
"\n"
"from cryptobot.webhook import InMemoryReplayKeyStore, Listener\n"
"\n"
"\n"
"def handle_webhook(headers, data):\n"
"    if data.get(\"update_type\") == \"invoice_paid\":\n"
"        payload = data.get(\"payload\", {})\n"
"        print(\"Paid invoice:\", payload.get(\"invoice_id\"))\n"
"\n"
"\n"
"listener = Listener(\n"
"    host=\"0.0.0.0\",\n"
"    callback=handle_webhook,\n"
"    api_token=os.environ[\"CRYPTOBOT_API_TOKEN\"],\n"
"    replay_store=InMemoryReplayKeyStore(),\n"
"    replay_ttl_seconds=3600,\n"
"    port=2203,\n"
"    url=\"/webhook\",\n"
"    log_level=\"info\",\n"
")\n"
"listener.listen()\n"

#: ../../usage.md:359
msgid ""
"The listener automatically verifies signatures, can reject duplicate "
"replayed webhook payloads, and provides a startup banner. `callback` can "
"be synchronous (`def`) or asynchronous (`async def`)."
msgstr ""
"El listener verifica automáticamente las firmas, puede rechazar payloads "
"de webhook duplicados/repetidos y proporciona un banner de inicio. `callback` "
"puede ser síncrono (`def`) o asíncrono (`async def`)."

#: ../../usage.md:362
msgid "For custom replay de-duplication keys, provide `replay_key_resolver`:"
msgstr "Para claves de deduplicación de repetición personalizadas, proporcione `replay_key_resolver`:"

#: ../../usage.md:364
#, python-brace-format
msgid ""
"def replay_key_resolver(data, raw_body, headers):\n"
"    payload = data.get(\"payload\", {})\n"
"    invoice_id = payload.get(\"invoice_id\")\n"
"    if invoice_id is not None:\n"
"        return f\"invoice_paid:{invoice_id}\"\n"
"    return None\n"
msgstr ""
"def replay_key_resolver(data, raw_body, headers):\n"
"    payload = data.get(\"payload\", {})\n"
"    invoice_id = payload.get(\"invoice_id\")\n"
"    if invoice_id is not None:\n"
"        return f\"invoice_paid:{invoice_id}\"\n"
"    return None\n"

#: ../../usage.md:373
msgid "Custom Webhook Handler"
msgstr "Manejador de Webhook Personalizado"

#: ../../usage.md:375
msgid ""
"You can also create your own webhook handler and verify signatures with "
"`check_signature`:"
msgstr ""
"También puede crear su propio manejador de webhook y verificar firmas con "
"`check_signature`:"

#: ../../usage.md:377
#, python-brace-format
msgid ""
"import json\n"
"import os\n"
"\n"
"from cryptobot.webhook import check_signature\n"
"from fastapi import FastAPI, Request, HTTPException\n"
"\n"
"app = FastAPI()\n"
"api_token = os.environ[\"CRYPTOBOT_API_TOKEN\"]\n"
"\n"
"@app.post(\"/webhook\")\n"
"async def webhook_handler(request: Request):\n"
"    # Read the raw body first (required for signature verification)\n"
"    raw_body = await request.body()\n"
"    raw_body_str = raw_body.decode(\"utf-8\")\n"
"\n"
"    if not check_signature(api_token, raw_body_str, request.headers):\n"
"        raise HTTPException(status_code=400, detail=\"Invalid "
"signature\")\n"
"\n"
"    data = json.loads(raw_body_str)\n"
"    # Process the verified webhook data\n"
"    # ...\n"
"\n"
"    return {\"ok\": True}\n"
msgstr ""
"import json\n"
"import os\n"
"\n"
"from cryptobot.webhook import check_signature\n"
"from fastapi import FastAPI, Request, HTTPException\n"
"\n"
"app = FastAPI()\n"
"api_token = os.environ[\"CRYPTOBOT_API_TOKEN\"]\n"
"\n"
"@app.post(\"/webhook\")\n"
"async def webhook_handler(request: Request):\n"
"    # Leer el cuerpo crudo primero (requerido para verificación de firma)\n"
"    raw_body = await request.body()\n"
"    raw_body_str = raw_body.decode(\"utf-8\")\n"
"\n"
"    if not check_signature(api_token, raw_body_str, request.headers):\n"
"        raise HTTPException(status_code=400, detail=\"Invalid "
"signature\")\n"
"\n"
"    data = json.loads(raw_body_str)\n"
"    # Procesar los datos verificados del webhook\n"
"    # ...\n"
"\n"
"    return {\"ok\": True}\n"

