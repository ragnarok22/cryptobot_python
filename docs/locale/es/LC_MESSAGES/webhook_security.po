#: ../../webhook_security.md:111
msgid ""
"If your integration has a stable business identifier, use "
"`replay_key_resolver`:"
msgstr ""
"Si su integración tiene un identificador de negocio estable, use "
"`replay_key_resolver`:"

#: ../../webhook_security.md:113
#, python-brace-format
msgid ""
"import os\n"
"\n"
"from cryptobot.webhook import InMemoryReplayKeyStore, Listener\n"
"\n"
"\n"
"def replay_key_resolver(data, raw_body, headers):\n"
"    payload = data.get(\"payload\", {})\n"
"    invoice_id = payload.get(\"invoice_id\")\n"
"    if invoice_id is not None:\n"
"        return f\"invoice_paid:{invoice_id}\"\n"
"    return None\n"
"\n"
"\n"
"listener = Listener(\n"
"    host=\"127.0.0.1\",\n"
"    callback=handle_webhook,\n"
"    api_token=os.environ[\"CRYPTOBOT_API_TOKEN\"],\n"
"    replay_store=InMemoryReplayKeyStore(),\n"
"    replay_ttl_seconds=3600,\n"
"    replay_key_resolver=replay_key_resolver,\n"
")\n"
msgstr ""
"import os\n"
"\n"
"from cryptobot.webhook import InMemoryReplayKeyStore, Listener\n"
"\n"
"\n"
"def replay_key_resolver(data, raw_body, headers):\n"
"    payload = data.get(\"payload\", {})\n"
"    invoice_id = payload.get(\"invoice_id\")\n"
"    if invoice_id is not None:\n"
"        return f\"invoice_paid:{invoice_id}\"\n"
"    return None\n"
"\n"
"\n"
"listener = Listener(\n"
"    host=\"127.0.0.1\",\n"
"    callback=handle_webhook,\n"
"    api_token=os.environ[\"CRYPTOBOT_API_TOKEN\"],\n"
"    replay_store=InMemoryReplayKeyStore(),\n"
"    replay_ttl_seconds=3600,\n"
"    replay_key_resolver=replay_key_resolver,\n"
")\n"

#: ../../webhook_security.md:137
msgid "Deployment Hardening"
msgstr "Endurecimiento del Despliegue"

#: ../../webhook_security.md:139
msgid "Use HTTPS at the public edge."
msgstr "Use HTTPS en el borde público."

#: ../../webhook_security.md:140
msgid "Bind app to `127.0.0.1` behind Nginx/Caddy/ingress when possible."
msgstr "Vincule la aplicación a `127.0.0.1` detrás de Nginx/Caddy/ingress cuando sea posible."

#: ../../webhook_security.md:141
msgid "Apply request limits and upstream timeouts."
msgstr "Aplique límites de solicitudes y timeouts del upstream."

#: ../../webhook_security.md:142
msgid "Keep webhook handler fast; queue expensive work."
msgstr "Mantenga el manejador de webhook rápido; encole el trabajo costoso."

#: ../../webhook_security.md:143
msgid "Never log secrets or full raw payloads in production."
msgstr "Nunca registre secretos o payloads crudos completos en producción."

