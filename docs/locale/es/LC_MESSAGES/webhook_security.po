#: ../../webhook_security.md:164
msgid "Queue-Based Processing"
msgstr "Procesamiento Basado en Cola"

#: ../../webhook_security.md:166
msgid "Move non-trivial business logic off the request thread."
msgstr "Mueva la lógica de negocio no trivial fuera del hilo de la solicitud."

#: ../../webhook_security.md:168
msgid ""
"from queue import Queue\n"
"from threading import Thread\n"
"\n"
"work_q: Queue[dict] = Queue(maxsize=1000)\n"
"\n"
"\n"
"def worker():\n"
"    while True:\n"
"        update = work_q.get()\n"
"        try:\n"
"            # Process invoice_paid, transfer_completed, etc.\n"
"            pass\n"
"        finally:\n"
"            work_q.task_done()\n"
"\n"
"\n"
"def handle_webhook(headers, data):\n"
"    work_q.put_nowait(data)\n"
"\n"
"\n"
"Thread(target=worker, daemon=True).start()\n"
msgstr ""
"from queue import Queue\n"
"from threading import Thread\n"
"\n"
"work_q: Queue[dict] = Queue(maxsize=1000)\n"
"\n"
"\n"
"def worker():\n"
"    while True:\n"
"        update = work_q.get()\n"
"        try:\n"
"            # Procesar invoice_paid, transfer_completed, etc.\n"
"            pass\n"
"        finally:\n"
"            work_q.task_done()\n"
"\n"
"\n"
"def handle_webhook(headers, data):\n"
"    work_q.put_nowait(data)\n"
"\n"
"\n"
"Thread(target=worker, daemon=True).start()\n"

