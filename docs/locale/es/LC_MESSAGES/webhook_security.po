#: ../../webhook_security.md:1
msgid "Webhook Security Guide"
msgstr "Guía de Seguridad de Webhooks"

#: ../../webhook_security.md:3
msgid ""
"This guide explains how to safely receive Crypto Bot webhook events in "
"production."
msgstr ""
"Esta guía explica cómo recibir de forma segura los eventos de webhook de "
"Crypto Bot en producción."

#: ../../webhook_security.md:5
msgid "Threat Model"
msgstr "Modelo de Amenazas"

#: ../../webhook_security.md:7
msgid ""
"A webhook endpoint is a public HTTP surface. Without verification and "
"controls, attackers can:"
msgstr ""
"Un endpoint de webhook es una superficie HTTP pública. Sin verificación y "
"controles, los atacantes pueden:"

#: ../../webhook_security.md:9
msgid "Forge payment notifications"
msgstr "Falsificar notificaciones de pago"

#: ../../webhook_security.md:10
msgid "Replay old updates"
msgstr "Reproducir actualizaciones antiguas"

#: ../../webhook_security.md:11
msgid "Exhaust worker capacity with burst traffic"
msgstr "Agotar la capacidad de los workers con tráfico en ráfagas"

#: ../../webhook_security.md:13
msgid "Signature Verification"
msgstr "Verificación de Firma"

#: ../../webhook_security.md:15
msgid "Crypto Bot signs each request with:"
msgstr "Crypto Bot firma cada solicitud con:"

#: ../../webhook_security.md:17
msgid "HMAC-SHA256(SHA256(api_token), raw_request_body)\n"
msgstr "HMAC-SHA256(SHA256(api_token), raw_request_body)\n"

#: ../../webhook_security.md:21
msgid "The signature arrives in the `crypto-pay-api-signature` header."
msgstr "La firma llega en el encabezado `crypto-pay-api-signature`."

#: ../../webhook_security.md:23
msgid "Recommended: Use `Listener`"
msgstr "Recomendado: Usar `Listener`"

#: ../../webhook_security.md:25
msgid "`Listener` verifies signatures before executing your callback."
msgstr "`Listener` verifica las firmas antes de ejecutar su callback."

#: ../../webhook_security.md:27
#, python-brace-format
msgid ""
"import os\n"
"\n"
"from cryptobot.webhook import InMemoryReplayKeyStore, Listener\n"
"\n"
"\n"
"def handle_webhook(headers, data):\n"
"    if data.get(\"update_type\") == \"invoice_paid\":\n"
"        payload = data.get(\"payload\", {})\n"
"        print(\"Verified payment for invoice\", "
"payload.get(\"invoice_id\"))\n"
"\n"
"\n"
"listener = Listener(\n"
"    host=\"127.0.0.1\",  # Prefer localhost behind reverse proxy\n"
"    callback=handle_webhook,\n"
"    api_token=os.environ[\"CRYPTOBOT_API_TOKEN\"],\n"
"    replay_store=InMemoryReplayKeyStore(),\n"
"    replay_ttl_seconds=3600,\n"
"    port=2203,\n"
"    url=\"/webhook\",\n"
"    log_level=\"info\",\n"
")\n"
"listener.listen()\n"
msgstr ""
"import os\n"
"\n"
"from cryptobot.webhook import InMemoryReplayKeyStore, Listener\n"
"\n"
"\n"
"def handle_webhook(headers, data):\n"
"    if data.get(\"update_type\") == \"invoice_paid\":\n"
"        payload = data.get(\"payload\", {})\n"
"        print(\"Verified payment for invoice\", "
"payload.get(\"invoice_id\"))\n"
"\n"
"\n"
"listener = Listener(\n"
"    host=\"127.0.0.1\",  # Preferir localhost detrás de proxy reverso\n"
"    callback=handle_webhook,\n"
"    api_token=os.environ[\"CRYPTOBOT_API_TOKEN\"],\n"
"    replay_store=InMemoryReplayKeyStore(),\n"
